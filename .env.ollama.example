# ===== LLM API (Ollama local) =====
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:3b-instruct

# ===== Zep Memory Graph =====
# Free tier is sufficient for basic use: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Chunking =====
CHUNK_SIZE=2000
CHUNK_OVERLAP=100

# ===== Ontology / Entity Caps =====
MAX_ENTITY_TYPES=6
MAX_EDGE_TYPES=6
MAX_GRAPH_NODES=50

# ===== Agent Persona Generation =====
MAX_AGENT_COUNT=15
SKIP_ZEP_SEARCH=true
PARALLEL_PROFILE_COUNT=2

# ===== Simulation Tuning =====
MAX_SIMULATION_HOURS=24
MAX_CONTEXT_LENGTH=8000
OASIS_SEMAPHORE=5

# ===== Boost LLM (optional) =====
# Leave these out entirely if you don't use a separate boost model.
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
